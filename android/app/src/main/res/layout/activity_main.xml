<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0A1E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo + Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ScamScan"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#C4B5FD"
            android:layout_marginTop="32dp"
            android:letterSpacing="0.04" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Call Scam Detector"
            android:textSize="13sp"
            android:textColor="#8B7FAD"
            android:layout_marginBottom="36dp" />

        <!-- Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <View
                    android:id="@+id/statusIndicator"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/dot_red"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#8B7FAD"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Complete setup below to enable live detection"
                android:textColor="#F0EBFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Permission status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERMISSIONS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8B7FAD"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvPermissionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Checking…"
                android:textColor="#F0EBFF"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.6"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnRequestPermissions"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Grant Audio &amp; Phone Permissions"
                android:textSize="13sp"
                android:backgroundTint="#8B5CF6"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnOverlayPermission"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Enable Overlay Permission"
                android:textSize="13sp"
                android:backgroundTint="#160F2E"
                android:textColor="#8B5CF6" />
        </LinearLayout>

        <!-- Server URL card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SERVER URL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#8B7FAD"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="WebSocket URL of your ScamScan backend. Use your local IP (e.g. ws://192.168.1.x:8000) when on the same Wi-Fi."
                android:textColor="#8B7FAD"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/etServerUrl"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="ws://192.168.1.x:8000"
                android:inputType="textUri"
                android:textColor="#F0EBFF"
                android:textColorHint="#4A3D6E"
                android:background="@drawable/input_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Save Settings"
                android:backgroundTint="#8B5CF6"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- How it works note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Once set up, ScamScan automatically activates when you answer a call. A floating overlay shows the risk level in real time."
            android:textColor="#8B7FAD"
            android:textSize="12sp"
            android:lineSpacingMultiplier="1.5"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
